# EcoSphere — Production environment
NODE_ENV=production

POSTGRES_USER=ecosphere
POSTGRES_PASSWORD=replace-with-production-postgres-password-min-64-chars-cryptographically-random-value
POSTGRES_DB=ecosphere
DATABASE_URL=postgresql://ecosphere:replace-with-production-postgres-password-min-64-chars-cryptographically-random-value@ecosphere-db:5432/ecosphere

DB_POOL_MAX=50
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
DB_PREPARE_STATEMENTS=true

REDIS_URL=redis://redis:6379

JWT_ACCESS_SECRET=replace-with-production-access-secret-min-64-chars-cryptographically-random-value!!
JWT_REFRESH_SECRET=replace-with-production-refresh-secret-min-64-chars-cryptographically-random-value!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_SECURE=true
CORS_ORIGIN=https://app.ecosphere.example.com

API_PORT=3000
API_HOST=0.0.0.0

VITE_API_URL=/api/v1
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

ECOSPHERE_SEED_ON_MIGRATE=false
ECOSPHERE_SEED_ON_START=false

UPLOAD_DIR=/var/lib/ecosphere/uploads
MAX_UPLOAD_BYTES=10485760

S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=ecosphere-production-uploads
S3_ACCESS_KEY=replace-with-production-s3-access-key
S3_SECRET_KEY=replace-with-production-s3-secret-key
S3_REGION=us-east-1
