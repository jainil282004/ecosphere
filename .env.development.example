# EcoSphere — Development environment
NODE_ENV=development

# PostgreSQL (host-run apps connect to published Docker port)
POSTGRES_USER=ecosphere
POSTGRES_PASSWORD=ecosphere_secret
POSTGRES_DB=ecosphere
POSTGRES_PUBLISHED_PORT=5432
DATABASE_URL=postgresql://ecosphere:ecosphere_secret@localhost:5432/ecosphere

# Connection pool (postgres.js via @ecosphere/db)
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
DB_PREPARE_STATEMENTS=true

# Redis
REDIS_PUBLISHED_PORT=6379
REDIS_URL=redis://localhost:6379

# JWT (development-only secrets — rotate in staging/production)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies & CORS (local HTTP)
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# API
API_PORT=3000
API_HOST=0.0.0.0

# Frontend (Vite dev server)
VITE_API_URL=http://localhost:3000/api/v1

# Reverse proxy (full-stack Docker profile)
NGINX_HTTP_PORT=8080

# Seed policy
ECOSPHERE_SEED_ON_MIGRATE=true
ECOSPHERE_SEED_ON_START=false

# File storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760

# Object storage (optional)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
