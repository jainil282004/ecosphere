# PostgreSQL
DATABASE_URL=postgresql://ecosphere:ecosphere_secret@localhost:5432/ecosphere

# Database pool tuning
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30
DB_POOL_CONNECT_TIMEOUT=10
DB_PREPARE_STATEMENTS=true

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Cookies (set false for local HTTP dev without TLS)
COOKIE_SECURE=false

# API
API_PORT=3000
API_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5173

# Frontend
VITE_API_URL=http://localhost:3000/api/v1

# File storage (local dev)
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=10485760

# Object storage (optional production)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1
